import java.util.*;
import java.lang.*;
import java.io.*;

class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc=new Scanner(System.in);
		String str=sc.nextLine();
		boolean flag=false;
		int count=0;
		char[] arr=str.toCharArray();
		for(int i=0;i<arr.length;i++){
		char ch=arr[i];
		if(ch!='_'){
		    
		        flag=true;
		   
		}
		   else{
		        if(flag){
		            count++;
		            flag=false;
		        }
		    }
		}
		if(flag)count++;
		
		
		System.out.print(count);

	}
}
